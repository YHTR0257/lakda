{
  "mcpServers": {
    "markdown-rag": {
      "comment": "MCP-Markdown-RAG - Semantic search for markdown documents",
      "serverPath": "{path/to}/MCP-Markdown-RAG",
      "command": "uv",
      "args": [
        "--directory",
        "{path/to}/MCP-Markdown-RAG",
        "run",
        "server.py"
      ]
    }
  },
  "note": "YOUR_USERNAMEを実際のユーザー名に置き換えてください (echo $HOME で確認可能)"
}
