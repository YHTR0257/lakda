# =============================================================================
# LAKDA Docker Compose Environment Variables
# =============================================================================
# Copy this file to ../../.env and modify as needed
# cp envs/.env.example .env

# =============================================================================
# Neo4j Database
# =============================================================================
NEO4J_VERSION=5
NEO4J_CONTAINER_NAME=lakda-database
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_URI_BOLT=bolt://lakda-database:7687
NEO4J_URI_NEO4J=neo4j://lakda-database:7687
NEO4J_PLUGINS=["apoc"]
NEO4J_UNRESTRICTED_PROCEDURES=apoc.*

# Database Healthcheck
DB_HEALTHCHECK_INTERVAL=10s
DB_HEALTHCHECK_TIMEOUT=5s
DB_HEALTHCHECK_RETRIES=5

# =============================================================================
# Backend (FastAPI)
# =============================================================================
BACKEND_CONTAINER_NAME=lakda-backend
BACKEND_PORT=8000
BACKEND_BUILD_TARGET=development
LOG_LEVEL=info

# Backend Resource Limits
BACKEND_CPUS_LIMIT=1
BACKEND_MEMORY_LIMIT=512M

# =============================================================================
# Frontend (Next.js)
# =============================================================================
FRONTEND_CONTAINER_NAME=lakda-frontend
FRONTEND_PORT=3000
FRONTEND_BUILD_TARGET=development
NEXT_PUBLIC_API_URL=http://localhost:8000/
NEXT_PUBLIC_LOG_LEVEL=info

# Frontend Resource Limits
FRONTEND_CPUS_LIMIT=1
FRONTEND_MEMORY_LIMIT=512M

# =============================================================================
# LLM Source (llamacpp | vllm)
# =============================================================================
LLM_SOURCE=llamacpp

# Dev環境: ホストで llama.cpp サーバーを起動し host.docker.internal 経由でアクセス
LLAMACPP_LLM_URL=http://host.docker.internal:11406
LLAMACPP_EMBEDDING_URL=http://host.docker.internal:11407

# =============================================================================
# LLM API Keys
# =============================================================================
OPENAI_API_KEY="your-openai-api-key"
ANTHROPIC_API_KEY="your-anthropic-api-key"
GOOGLE_API_KEY="your-google-api-key"
OPENROUTER_API_KEY="your-openrouter-api-key"
