# =============================================================================
# LAKDA Docker Compose Environment Variables (Production)
# =============================================================================
# Copy this file to ../../.env and modify as needed
# cp envs/.env.prod.example .env

# =============================================================================
# Global Settings
# =============================================================================
PROJECT_NAME=lakda
ENVIRONMENT=production
DOC_DATA_PATH=./data/

# =============================================================================
# Neo4j Database
# =============================================================================
NEO4J_VERSION=5
NEO4J_CONTAINER_NAME=lakda-database
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-password
DATABASE_URL_BOLT=bolt://lakda-database:7687
DATABASE_URL_NEO4J=neo4j://lakda-database:7687
NEO4J_PLUGINS=["apoc"]
NEO4J_UNRESTRICTED_PROCEDURES=apoc.*
NEO4J_APOC_EXPORT_FILE_ENABLED=true
NEO4J_APOC_IMPORT_FILE_ENABLED=true
NEO4J_APOC_IMPORT_FILE_USE_NEO4J_CONFIG=true

# Database Healthcheck
DB_HEALTHCHECK_INTERVAL=10s
DB_HEALTHCHECK_TIMEOUT=5s
DB_HEALTHCHECK_RETRIES=5

# Neo4j Resource Limits
NEO4J_CPUS_LIMIT=2
NEO4J_MEMORY_LIMIT=4G

# =============================================================================
# Backend (FastAPI)
# =============================================================================
BACKEND_CONTAINER_NAME=lakda-backend
BACKEND_PORT=8000
BACKEND_BUILD_TARGET=production
LOG_LEVEL=warning

# Backend Resource Limits
BACKEND_CPUS_LIMIT=2
BACKEND_MEMORY_LIMIT=1G

# =============================================================================
# Frontend (Next.js)
# =============================================================================
FRONTEND_CONTAINER_NAME=lakda-frontend
FRONTEND_PORT=3000
FRONTEND_BUILD_TARGET=production
NEXT_PUBLIC_API_URL=https://your-domain.com/api/
NEXT_PUBLIC_LOG_LEVEL=warning

# Frontend Resource Limits
FRONTEND_CPUS_LIMIT=1
FRONTEND_MEMORY_LIMIT=512M

# =============================================================================
# LLM Source (llamacpp | vllm)
# =============================================================================
LLM_SOURCE=llamacpp

# llama.cpp サーバー（Docker コンテナまたは外部サーバー）
LLAMACPP_LLM_URL=http://llamacpp-llm:11406
LLAMACPP_EMBEDDING_URL=http://llamacpp-embedding:11407

# llama.cpp Resource Limits（コンテナで動かす場合）
LLAMACPP_CPUS_LIMIT=4
LLAMACPP_MEMORY_LIMIT=16G

# =============================================================================
# LLM API Keys
# =============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
