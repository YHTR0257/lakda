# =============================================================================
# LAKDA Docker Compose Environment Variables (Production)
# =============================================================================
# Copy this file to ../../.env and modify as needed
# cp envs/.env.prod.example .env

# =============================================================================
# Neo4j Database
# =============================================================================
NEO4J_VERSION=5
NEO4J_CONTAINER_NAME=lakda-database
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-password
NEO4J_URI_BOLT=bolt://lakda-database:7687
NEO4J_URI_NEO4J=neo4j://lakda-database:7687
NEO4J_PLUGINS=["apoc"]
NEO4J_UNRESTRICTED_PROCEDURES=apoc.*

# Database Healthcheck
DB_HEALTHCHECK_INTERVAL=10s
DB_HEALTHCHECK_TIMEOUT=5s
DB_HEALTHCHECK_RETRIES=5

# Neo4j Resource Limits
NEO4J_CPUS_LIMIT=2
NEO4J_MEMORY_LIMIT=4G

# =============================================================================
# Backend (FastAPI)
# =============================================================================
BACKEND_CONTAINER_NAME=lakda-backend
BACKEND_PORT=8000
BACKEND_BUILD_TARGET=production
LOG_LEVEL=warning

# Backend Resource Limits
BACKEND_CPUS_LIMIT=2
BACKEND_MEMORY_LIMIT=1G

# =============================================================================
# Frontend (Next.js)
# =============================================================================
FRONTEND_CONTAINER_NAME=lakda-frontend
FRONTEND_PORT=3000
FRONTEND_BUILD_TARGET=production
NEXT_PUBLIC_API_URL=https://your-domain.com/api/
NEXT_PUBLIC_LOG_LEVEL=warning

# Frontend Resource Limits
FRONTEND_CPUS_LIMIT=1
FRONTEND_MEMORY_LIMIT=512M

# =============================================================================
# Ollama (Local LLM) - Docker Container with NVIDIA GPU
# =============================================================================
OLLAMA_VERSION=latest
OLLAMA_CONTAINER_NAME=lakda-ollama
OLLAMA_PORT=11434
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_URL=http://ollama:11434

# NVIDIA GPU Settings
NVIDIA_VISIBLE_DEVICES=all
OLLAMA_GPU_COUNT=all

# Ollama Resource Limits
OLLAMA_CPUS_LIMIT=4
OLLAMA_MEMORY_LIMIT=16G

# =============================================================================
# LLM API Keys
# =============================================================================
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
